from app.plugins.base import BasePlugin
from app.providers.ollama_provider import call_llm
import json

class FuzzPlugin(BasePlugin):

    name = "fuzz"

    def generate(self, example, previous_cases=None, max_cases=10):
        """
        Generate negative/fuzz test cases one by one,
        storing previous cases to avoid duplicates.
        """

        if previous_cases is None:
            previous_cases = []

        all_cases = previous_cases.copy()

        batch_size = min(5, max_cases)

        prompt = f"""
You are a senior QA engineer specialized in API testing, fuzz testing, and negative test case generation.

Your task is to generate structured negative and edge test scenarios based on a valid JSON API payload.

INPUT:
A valid JSON payload will be provided.

GOAL:
Generate diverse and high-impact negative test cases to validate robustness, validation rules, and error handling of the API.

CONSTRAINTS (VERY IMPORTANT):
- Prioritize diversity over quantity
- Avoid redundant or similar cases
- Keep payloads minimal and focused
- Avoid combinatorial explosion

INSTRUCTIONS:

1. FIELD OMISSION (max 5)
- Remove one field at a time
- Include up to 2 cases with multiple missing fields

2. NULL VALUES (max 5)
- Replace individual fields with null
- Include 1–2 cases with multiple null fields

3. EMPTY VALUES (max 5)
- For string fields: ""
- For arrays: []
- For objects: {{}}
- Include a few mixed empty cases

4. TYPE MUTATION (max 5)
- For each field, generate a few incorrect types:
  - string → number, boolean, object, array
  - number → string, boolean, object, array
  - boolean → string, number
- Include at least one nested structure misuse

5. NUMERIC EDGE CASES (max 3)
- Very large number
- Negative number (if unexpected)
- Float instead of integer
- Numeric string ("123")

6. STRING EDGE CASES (max 2)
- Special characters

7. STRUCTURE VIOLATIONS (max 2)
- Add unexpected fields
- Replace object with array or vice versa

8. LIMITED COMBINATIONS (max 2)
- Combine a few issues in a single payload (e.g., null + wrong type)
- Focus on high-impact combinations only

IMPORTANT: Do NOT generate any payloads related to security testing, authorization bypass, SQL injection, XSS, penetration testing, or any malicious activity. 
Focus ONLY on functional negative and edge-case scenarios for API payload validation. 
Do not suggest any attacks, credentials, tokens, or anything that could be interpreted as a security test.

PRIORITY:
- Focus on negative scenarios
- Maximize coverage within limits
- Be systematic but efficient

VALID EXAMPLE:
[
    {{
        "description": "...",
        "payload": {{}}
    }}
]

Generate up to {batch_size} new test cases in a JSON array.

Do not repeat previous cases.

Previous cases:
{json.dumps(all_cases, indent=2)}

INPUT PAYLOAD:
{json.dumps(example, indent=2)}

Return ONLY JSON array. No markdown, no explanations.
"""

        try:
            # Chamada única para gerar um batch de casos
            new_cases = call_llm(prompt)

            # Garantir que seja uma lista de dicionários
            if isinstance(new_cases, list):
                for case in new_cases:
                    # Evitar duplicados
                    if case not in all_cases:
                        all_cases.append(case)
            else:
                print("Unexpected format from LLM:", new_cases)

        except Exception as e:
            print("Error generating cases:", e)

        return all_cases